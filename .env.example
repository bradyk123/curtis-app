# Copy to ".env" and fill in from your Supabase project:
# Dashboard → Project Settings → API

# --- Frontend (safe to expose; embedded in the built app) ---
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Server-side only, used by scripts/seed_supabase.mjs ---
# NEVER commit this or ship it to the browser. It bypasses row-level security.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key
